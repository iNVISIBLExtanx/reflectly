                # Success rates bar chart
                algorithms = list(success_rates.keys())
                rates = [success_rates[algo] * 100 for algo in algorithms]
                
                bars1 = ax1.bar(algorithms, rates, color=['#1f77b4', '#ff7f0e', '#2ca02c'])
