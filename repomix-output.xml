                disabled={isRunningValidation}
                style={{
                  padding: '8px 16px',
                  backgroundColor: '#28a745',
                  color: 'white',
                  border: 'none',
                  borderRadius: '5px',
                  cursor: 'pointer',
                  fontWeight: 'bold'
                }}
              >
                {isRunningValidation ? '🔄 Running...' : '🧪 Run Validation'}
              </button>
            </div>
          </div>
