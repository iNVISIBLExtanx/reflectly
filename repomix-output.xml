                    stats['wins'] += 1
        
        # Calculate averages
        for algorithm, stats in algorithm_stats.items():
            if stats['success_rate'] > 0:
                stats['avg_time_ms'] /= stats['success_rate']
                stats['avg_nodes_explored'] /= stats['success_rate']
